name: scan

on:
  push:
    branches: ["main"]
  pull_request:

permissions:
  contents: read

concurrency:
  group: scan-{% raw %}${{ github.ref }}{% endraw %}
  cancel-in-progress: true

jobs:
  scan:
    runs-on: ubuntu-latest
    timeout-minutes: 15
    steps:
      - uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0 # v7.0.0
        with:
          fetch-depth: 0
          persist-credentials: false
      - uses: astral-sh/setup-uv@fac544c07dec837d0ccb6301d7b5580bf5edae39 # v8.2.0
        with:
          version: "0.11.23"
          enable-cache: true
{%- if enable_sha_pin_policy %}
      - name: zizmor (workflow audit)
        env:
          GH_TOKEN: {% raw %}${{ github.token }}{% endraw %}
        run: uvx zizmor@1.26.1 --persona=regular .
{%- endif %}
{%- if enable_dependency_audit %}
      - name: pip-audit
        run: |
          uv export --frozen --no-emit-project --no-dev --no-hashes -o requirements-audit.txt
          uvx pip-audit@2.10.1 -r requirements-audit.txt
{%- endif %}
{%- if enable_scanners %}
      - name: semgrep
        run: uvx semgrep@1.167.0 scan --config .semgrep.yml --metrics=off --error .
      # gitleaks is installed from the mise.toml pin (single source of truth, kept fresh
      # by Renovate's native mise manager); install: false brings up the mise CLI only.
      - uses: jdx/mise-action@e6a8b3978addb5a52f2b4cd9d91eafa7f0ab959d # v4.2.0
        with:
          install: false
      - name: gitleaks
        run: |
          mise install gitleaks
          # Scan full commit history (checkout uses fetch-depth: 0); a working-tree
          # scan would miss secrets committed then deleted from the tree.
          mise exec -- gitleaks git . --redact --exit-code 1
{%- endif %}
