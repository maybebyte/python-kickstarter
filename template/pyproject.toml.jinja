[project]
# PEP 503 distribution name: MUST be the validated slug, NOT the free-text
# project_name. "Demo Project" (spaces/caps) is not a valid name and `uv lock`
# — run by the copy-only _tasks on every render — aborts the whole generation.
name = "{{ package_name }}"
version = "0.1.0"
# description / author_* are free text: escape backslash and double-quote so a value
# like `A "great" project` stays a valid TOML basic string — an unescaped " would break
# parsing and abort the copy-time `uv lock` (the package_name slug is already validated).
description = "{{ description | replace('\\', '\\\\') | replace('"', '\\"') }}"
authors = [{ name = "{{ author_name | replace('\\', '\\\\') | replace('"', '\\"') }}", email = "{{ author_email | replace('\\', '\\\\') | replace('"', '\\"') }}" }]
requires-python = ">={{ python_version }}"
readme = "README.md"
{%- if license != "proprietary" %}
license = "{{ license }}"
{%- endif %}
dependencies = []

{% if project_type == "library" -%}
[build-system]
requires = ["uv_build>=0.11.23,<0.12"]
build-backend = "uv_build"
{%- else -%}
[tool.uv]
package = false
{%- endif %}

[dependency-groups]
dev = [
    "ruff>=0.15,<0.16",
    # strict mode is version-coupled like ruff's ALL set: a new basedpyright minor can
    # add strict diagnostics that turn a green tree red, so cap it and bump deliberately.
    "basedpyright>=1.39,<1.40",
    "pytest>=8",
    "pytest-cov>=5",
    "pre-commit>=4",
{%- if enable_property_tests %}
    "hypothesis>=6",
{%- endif %}
{%- if enable_mutation_tests %}
    "mutmut>=3.6",
{%- endif %}
{%- if enable_dependency_audit %}
    "pip-audit>=2.10",
{%- endif %}
]

[tool.ruff]
line-length = 100
target-version = "py{{ python_version | replace('.', '') }}"

[tool.ruff.lint]
{% if ruff_ruleset == "all" -%}
select = ["ALL"]
ignore = [
    "E501", "ANN401", "PLR0913", "PLR2004", "TD002", "TD003", "FIX002",
    "EM101", "EM102", "TRY003", "D100", "D203", "D213", "COM812", "ISC001",
]
{%- else -%}
select = ["E", "F", "UP", "B", "SIM", "I", "ANN", "S", "C4", "DTZ", "PTH", "RUF", "PL"]
{%- endif %}

[tool.ruff.lint.mccabe]
max-complexity = 10

[tool.ruff.lint.pylint]
max-args = 8
max-branches = 12
max-returns = 6
max-statements = 50

[tool.ruff.lint.pydocstyle]
convention = "google"

[tool.ruff.lint.isort]
known-first-party = ["{{ package_name }}"]

[tool.ruff.lint.per-file-ignores]
"tests/**" = ["S101", "PLR2004", "ANN", "D", "INP001", "SLF001"]
{%- if project_type == "application" %}
# The application entry point intentionally prints; T201 (flake8-print) under
# select=ALL would otherwise fail `ruff check` on src/<pkg>/__main__.py.
"src/**/__main__.py" = ["T201"]
{%- endif %}

[tool.ruff.format]
quote-style = "double"
docstring-code-format = true

[tool.basedpyright]
typeCheckingMode = "strict"
pythonVersion = "{{ python_version }}"
include = ["src", "tests"]
reportMissingImports = "error"

[tool.pytest.ini_options]
minversion = "8.0"
testpaths = ["tests"]
{% if project_type == "application" -%}
pythonpath = ["src"]
{% endif -%}
markers = [
    "property: property-based Hypothesis tests (deselect with -m 'not property')",
]
addopts = [
    "-q",
    "--strict-markers",
    "--strict-config",
    "--import-mode=importlib",
    "--cov={{ package_name }}",
    "--cov-branch",
    "--cov-report=term-missing",
    "--cov-report=xml",
]

[tool.coverage.run]
branch = true
source = ["{{ package_name }}"]

[tool.coverage.paths]
source = ["src/{{ package_name }}", "*/site-packages/{{ package_name }}"]

[tool.coverage.report]
fail_under = {{ coverage_floor }}
show_missing = true
exclude_also = [
    "if TYPE_CHECKING:",
    "if __name__ == .__main__.:",
    "raise NotImplementedError",
    "@(abc\\.)?abstractmethod",
]
{% if enable_mutation_tests %}
[tool.mutmut]
source_paths = ["src/{{ package_name }}"]
pytest_add_cli_args_test_selection = ["tests/unit"]
# --no-cov (not `-p no:cov`): the cov plugin must stay loaded so the project's
# addopts `--cov` flags remain valid args; `-p no:cov` unloads it and pytest then
# rejects `--cov`, so mutmut silently leaves every mutant "not checked".
pytest_add_cli_args = ["--no-cov"]
mutate_only_covered_lines = false
{% endif -%}
